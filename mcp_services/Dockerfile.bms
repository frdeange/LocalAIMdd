# ── MCP BMS Service (PostgreSQL CRUD) ─────────────────────────
FROM python:3.13-slim

WORKDIR /app

COPY mcp_services/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY mcp_services/__init__.py ./mcp_services/__init__.py
COPY mcp_services/telemetry.py ./mcp_services/telemetry.py
COPY mcp_services/bms_server.py ./mcp_services/bms_server.py

ENV PYTHONUNBUFFERED=1
ENV BMS_SERVER_PORT=8093

EXPOSE 8093

CMD ["python", "-m", "mcp_services.bms_server"]
